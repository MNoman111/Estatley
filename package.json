{
  "name": "estatley",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Estatley — MERN real estate portal, deployable on Vercel",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "seed": "node backend/seed/seed.js",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1"
  }
}
