# Local development. On Vercel, set these in Project Settings → Environment Variables.
PORT=5000
# Local MongoDB, or a MongoDB Atlas connection string (required for Vercel):
MONGO_URI=mongodb://127.0.0.1:27017/zameen_clone
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
# Only needed for local two-server dev (frontend on 5173). Not needed on Vercel (same origin).
CLIENT_URL=http://localhost:5173
# Optional: enables the one-off POST /api/seed endpoint to populate a deployed DB.
SEED_SECRET=
